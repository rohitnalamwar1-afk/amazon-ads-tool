# Amazon Advertising API (Login with Amazon)
AMAZON_CLIENT_ID=your_client_id
AMAZON_CLIENT_SECRET=your_client_secret
AMAZON_REFRESH_TOKEN=your_refresh_token
AMAZON_PROFILE_ID=your_profile_id

# OAuth redirect URI (must match Amazon Developer Console)
AMAZON_REDIRECT_URI=http://localhost:5000/api/auth/callback

# Frontend (CORS)
FRONTEND_URL=http://localhost:3000

# Server
PORT=5000
